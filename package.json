{
    "name": "@he4rt/sycorax",
    "license": "MIT",
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "bun@1.3.12",
    "scripts": {
        "build": "bunx --bun vite build",
        "dev": "bunx --bun vite",
        "format": "bunx --bun prettier --write \"**/*.{js,ts,json,yml,md,css,blade.php}\"",
        "prepare": "husky",
        "outdated": "npm-check-updates"
    },
    "devDependencies": {
        "@prettier/plugin-php": "0.25.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "4.2.2",
        "autoprefixer": "10.4.27",
        "axios": "1.15.0",
        "concurrently": "9.2.1",
        "husky": "9.1.7",
        "laravel-vite-plugin": "3.0.1",
        "lint-staged": "16.4.0",
        "npm-check-updates": "20.0.1",
        "prettier": "3.8.2",
        "prettier-plugin-blade": "3.1.4",
        "prettier-plugin-tailwindcss": "0.7.2",
        "tailwindcss": "4.2.2",
        "vite": "8.0.8"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.1",
        "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
        "lightningcss-linux-x64-gnu": "1.32.0"
    },
    "lint-staged": {
        "*.{js,ts,json,yml,md,css,blade.php}": [
            "prettier --write"
        ],
        "*.php": [
            "vendor/bin/rector process",
            "vendor/bin/pint"
        ]
    }
}
